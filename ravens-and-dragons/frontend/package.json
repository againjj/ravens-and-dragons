{
  "name": "ravens-and-dragons-frontend",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/main/frontend/ravens-and-dragons-entry.ts",
      "default": "./src/main/frontend/ravens-and-dragons-entry.ts"
    },
    "./app-integration": {
      "types": "./src/main/frontend/app-integration.ts",
      "default": "./src/main/frontend/app-integration.ts"
    },
    "./game-client": {
      "types": "./src/main/frontend/game-client.ts",
      "default": "./src/main/frontend/game-client.ts"
    },
    "./useGameSession": {
      "types": "./src/main/frontend/features/game/useGameSession.ts",
      "default": "./src/main/frontend/features/game/useGameSession.ts"
    },
    "./useBoardSizing": {
      "types": "./src/main/frontend/hooks/useBoardSizing.ts",
      "default": "./src/main/frontend/hooks/useBoardSizing.ts"
    },
    "./types": {
      "types": "./src/main/frontend/game-types.ts",
      "default": "./src/main/frontend/game-types.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "vite",
    "test": "node --test src/test/frontend/**/*.test.js && vitest run"
  },
  "dependencies": {
    "@ravensanddragons/platform-frontend": "file:../../platform/frontend",
    "@reduxjs/toolkit": "2.8.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-redux": "9.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "19.1.2",
    "@types/react-dom": "19.1.2",
    "jsdom": "26.1.0",
    "typescript": "5.6.3",
    "vite": "8.0.16",
    "vitest": "^4.1.2"
  }
}

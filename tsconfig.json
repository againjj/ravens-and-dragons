{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "Bundler",
    "lib": ["DOM", "ES2020"],
    "strict": true,
    "outDir": "build/generated/frontend",
    "rootDir": "src/main/frontend",
    "skipLibCheck": true
  },
  "include": ["src/main/frontend/**/*.ts"]
}

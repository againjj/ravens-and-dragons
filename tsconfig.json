{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "lib": ["DOM", "ES2020"],
    "strict": true,
    "outDir": "build/generated/frontend",
    "rootDir": "src/main/frontend",
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true
  },
  "include": ["src/main/frontend/**/*.ts", "src/main/frontend/**/*.tsx"]
}
